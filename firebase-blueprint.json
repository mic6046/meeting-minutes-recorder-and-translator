{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a MinutesFlow AI user and their subscription/credits status.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The user's unique Firebase Auth UID." },
        "email": { "type": "string", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's full name." },
        "photoURL": { "type": "string", "description": "The user's profile photo URL." },
        "meetingCredits": { "type": "number", "description": "The number of remaining meeting credits available to the user." },
        "freeMinutesUsed": { "type": "number", "description": "Total free tier processing minutes consumed by the user." },
        "stripeCustomerId": { "type": "string", "description": "The connected Stripe customer ID." },
        "stripeSubscriptionId": { "type": "string", "description": "The active Stripe subscription ID." },
        "subscriptionStatus": { "type": "string", "enum": ["none", "active", "canceled", "past_due"], "description": "Current Stripe subscription status." },
        "accountType": { "type": "string", "enum": ["free", "paid", "admin"], "description": "The category of account." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When this record was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When this record was last updated." }
      },
      "required": ["id", "email", "meetingCredits"]
    },
    "Meeting": {
      "title": "Meeting",
      "description": "Represents a transcribed and AI-processed meeting.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique meeting processing ID." },
        "userId": { "type": "string", "description": "UID of the user who owns this meeting." },
        "title": { "type": "string", "description": "Title of the meeting." },
        "duration": { "type": "number", "description": "Duration of the meeting recording in seconds." },
        "language": { "type": "string", "description": "Spoken language of the meeting." },
        "summary": { "type": "string", "description": "AI-generated executive summary." },
        "minutes": { "type": "string", "description": "AI-generated rich markdown meeting minutes." },
        "actionItems": { "type": "string", "description": "AI-extracted key action items." },
        "status": { "type": "string", "enum": ["pending", "processed", "failed"], "description": "Current processing state." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When this meeting was created." }
      },
      "required": ["id", "userId", "title", "status", "createdAt"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Represents a credit purchase transaction processed via Stripe.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Stripe Session ID or internal transaction ID." },
        "userId": { "type": "string", "description": "UID of the user who made the purchase." },
        "stripePaymentIntent": { "type": "string", "description": "The payment intent ID generated by Stripe." },
        "stripeSessionId": { "type": "string", "description": "The checkout session ID." },
        "stripeInvoiceId": { "type": "string", "description": "The Stripe invoice ID for recurring billing." },
        "stripeSubscriptionId": { "type": "string", "description": "The Stripe subscription ID." },
        "amount": { "type": "number", "description": "Total amount paid in MYR cents (e.g. 2900 for RM29.00)." },
        "currency": { "type": "string", "description": "Currency of payment (MYR)." },
        "creditsPurchased": { "type": "number", "description": "Number of meeting credits added." },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"], "description": "Payment checkout state." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the payment session was initiated." }
      },
      "required": ["id", "userId", "amount", "currency", "creditsPurchased", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile, balance and status records."
    },
    "meetings/{meetingId}": {
      "schema": "Meeting",
      "description": "Transcribed and analyzed meeting documents."
    },
    "payments/{paymentId}": {
      "schema": "Payment",
      "description": "Transaction logs of purchased credits."
    }
  }
}
