# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# STRIPE_SECRET_KEY: Optional Stripe Secret Key for processing payments.
# If omitted, the app automatically runs in simulated Sandbox mode.
STRIPE_SECRET_KEY=""

# STRIPE_PRICE_1_CREDIT: One-time Stripe Price ID for 1 meeting credit (RM39.00 MYR).
STRIPE_PRICE_1_CREDIT="price_PLACEHOLDER_1_CREDIT"

# STRIPE_PRICE_5_CREDITS: One-time Stripe Price ID for 5 meeting credits (RM195.00 MYR).
STRIPE_PRICE_5_CREDITS="price_PLACEHOLDER_5_CREDITS"

# STRIPE_PRICE_10_CREDITS: One-time Stripe Price ID for 10 meeting credits (RM390.00 MYR).
STRIPE_PRICE_10_CREDITS="price_PLACEHOLDER_10_CREDITS"

# STRIPE_PRODUCT_ID: Optional reference — existing product prod_Uq9DBX2LStZqUi on Stripe.
STRIPE_PRODUCT_ID="prod_Uq9DBX2LStZqUi"

# STRIPE_WEBHOOK_SECRET: Stripe webhook signing secret for /api/stripe/webhook.
# Subscribe only to checkout.session.completed for one-time payments.
STRIPE_WEBHOOK_SECRET="whsec_YOUR_WEBHOOK_SECRET"

# APP_URL: Public base URL of the deployed app (no trailing slash).
# Used for Stripe checkout success/cancel redirects.
# Production custom domain (apex primary): https://minutesflow.com
# Optionally also connect www.minutesflow.com in App Hosting (redirect www → apex).
# Default hosted URL (until custom domain SSL is live):
#   https://meeting-minutes--gen-lang-client-0135145658.asia-southeast1.hosted.app
APP_URL="https://minutesflow.com"
